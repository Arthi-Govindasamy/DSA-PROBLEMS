class Solution {
    public boolean isPalindrome(int n) {
        // code here
        int original=n;
        int rev=0;
        while(n>0){
            int ld=n%10;
            rev=(10*rev)+ld;
            n=n/10;
        }
        return rev==original;
    }
}

