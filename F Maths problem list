6.................Given an integer n, find the number of divisors of n that are divisible by 3.
...............Number of divisors


class Solution {
    static int countDivisors(int n) {
        // code here
        int count=0;
        for(int i=1;i<=n;i++){
            if(n%i==0&&i%3==0){
                count++;
            }
        }
        return count;
    }
}

7............................Middle of Three
Given three distinct numbers a, b and c. Find the number with a value in the middle (Try to do it with minimum comparisons).
class Solution {
    int middle(int a, int b, int c) {
        // code here
        
        if(a>b&&a>c){
            return b>c?b:c;
        }
        else if(b>a&&b>c){
            return a>c?a:c;
        }
        else{
            return a>b?a:b;
        }
    }
}
 

